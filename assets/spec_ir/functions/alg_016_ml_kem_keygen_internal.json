{
  "function_id": "alg_016_ml_kem_keygen_internal",
  "name": "ML-KEM.KeyGen_internal",
  "label": "Algorithm 16",
  "page_start": 32,
  "page_end": 32,
  "inputs": [
    {
      "name": "d",
      "type": "byte_array",
      "description": "32-byte random seed"
    },
    {
      "name": "z",
      "type": "byte_array",
      "description": "32-byte random seed"
    }
  ],
  "outputs": [
    {
      "name": "ek",
      "type": "byte_array",
      "description": "384*k + 32-byte encapsulation key"
    },
    {
      "name": "dk",
      "type": "byte_array",
      "description": "768*k + 96-byte decapsulation key"
    }
  ],
  "body_raw": [
    "(ekPKE, dkPKE) <- K-PKE.KeyGen(d)",
    "ek <- ekPKE",
    "dk <- dkPKE || ek || H(ek) || z",
    "return (ek, dk)"
  ]
}