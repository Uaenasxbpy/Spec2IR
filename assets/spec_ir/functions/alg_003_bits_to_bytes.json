{
  "function_id": "alg_003_bits_to_bytes",
  "name": "BitsToBytes",
  "label": "Algorithm 3",
  "page_start": 20,
  "page_end": 20,
  "inputs": [
    {
      "name": "b",
      "type": "bit_array",
      "description": "Input bit array of length 8*l"
    }
  ],
  "outputs": [
    {
      "name": "B",
      "type": "byte_array",
      "description": "Output byte array of length l"
    }
  ],
  "body_raw": [
    "B <- (0, ..., 0)",
    "for (i <- 0; i < 8*l; i++)",
    "  B[floor(i/8)] <- B[floor(i/8)] + b[i] * 2^(i mod 8)",
    "end for",
    "return B"
  ]
}