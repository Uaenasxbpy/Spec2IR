{
  "function_id": "alg_005_byte_encode_d",
  "name": "ByteEncode_d",
  "label": "Algorithm 5",
  "page_start": 22,
  "page_end": 22,
  "inputs": [
    {
      "name": "F",
      "type": "int_array",
      "description": "Integer array of 256 elements modulo m, where m=2^d if d<12, m=q if d=12"
    }
  ],
  "outputs": [
    {
      "name": "B",
      "type": "byte_array",
      "description": "Byte array of length 32*d"
    }
  ],
  "body_raw": [
    "for (i <- 0; i < 256; i++)",
    "  a <- F[i]",
    "  for (j <- 0; j < d; j++)",
    "    b[i*d + j] <- a mod 2",
    "    a <- (a - b[i*d + j]) / 2",
    "  end for",
    "end for",
    "B <- BitsToBytes(b)",
    "return B"
  ]
}