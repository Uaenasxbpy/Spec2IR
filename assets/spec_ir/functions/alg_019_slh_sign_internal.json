{
  "function_id": "alg_019_slh_sign_internal",
  "name": "slh_sign_internal(M, SK, addrnd)",
  "label": "Algorithm 19",
  "page_start": 35,
  "page_end": 35,
  "inputs": [
    {
      "name": "M",
      "type": "byte_array",
      "description": "Message to sign"
    },
    {
      "name": "SK",
      "type": "byte_array",
      "description": "SLH-DSA private key: (SK.seed, SK.prf, PK.seed, PK.root)"
    },
    {
      "name": "addrnd",
      "type": "byte_array",
      "description": "Optional n-byte additional randomness for hedged signing; omit for deterministic signing"
    }
  ],
  "outputs": [
    {
      "name": "SIG",
      "type": "byte_array",
      "description": "SLH-DSA signature"
    }
  ],
  "body_raw": [
    "ADRS ← toByte(0, 32)",
    "opt_rand ← addrnd",
    "R ← PRF_msg(SK.prf, opt_rand, M)",
    "SIG ← R",
    "digest ← H_msg(R, PK.seed, PK.root, M)",
    "md ← digest[0 : ⌈k * a / 8⌉]",
    "tmp_idxtree ← digest[⌈k * a / 8⌉ : ⌈k * a / 8⌉ + ⌈(h - h'/d) / 8⌉]",
    "tmp_idxleaf ← digest[⌈k * a / 8⌉ + ⌈(h - h'/d) / 8⌉ : ⌈k * a / 8⌉ + ⌈(h - h'/d) / 8⌉ + ⌈h/(8d)⌉]",
    "idxtree ← toInt(tmp_idxtree, ⌈(h - h'/d) / 8⌉) mod 2^(h - h'/d)",
    "idxleaf ← toInt(tmp_idxleaf, ⌈h/(8d)⌉) mod 2^(h/d)",
    "ADRS.setTreeAddress(idxtree)",
    "ADRS.setTypeAndClear(FORS_TREE)",
    "ADRS.setKeyPairAddress(idxleaf)",
    "SIG_FORS ← fors_sign(md, SK.seed, PK.seed, ADRS)",
    "SIG ← SIG ∥ SIG_FORS",
    "PK_FORS ← fors_pkFromSig(SIG_FORS, md, PK.seed, ADRS)",
    "SIG_HT ← ht_sign(PK_FORS, SK.seed, PK.seed, idxtree, idxleaf)",
    "SIG ← SIG ∥ SIG_HT",
    "return SIG"
  ]
}