{
  "function_id": "alg_018_ml_kem_decaps_internal",
  "name": "ML-KEM.Decaps_internal",
  "label": "Algorithm 18",
  "page_start": 34,
  "page_end": 34,
  "inputs": [
    {
      "name": "dk",
      "type": "byte_array",
      "description": "768*k + 96-byte decapsulation key"
    },
    {
      "name": "c",
      "type": "byte_array",
      "description": "32*(d_u*k + d_v)-byte ciphertext"
    }
  ],
  "outputs": [
    {
      "name": "K",
      "type": "byte_array",
      "description": "32-byte shared secret key"
    }
  ],
  "body_raw": [
    "dkPKE <- dk[0 : 384*k]",
    "ekPKE <- dk[384*k : 768*k + 32]",
    "h <- dk[768*k + 32 : 768*k + 64]",
    "z <- dk[768*k + 64 : 768*k + 96]",
    "m_prime <- K-PKE.Decrypt(dkPKE, c)",
    "(K_prime, r_prime) <- G(m_prime || h)",
    "K_bar <- J(z || c)",
    "c_prime <- K-PKE.Encrypt(ekPKE, m_prime, r_prime)",
    "if c != c_prime then",
    "  K_prime <- K_bar",
    "end if",
    "return K_prime"
  ]
}