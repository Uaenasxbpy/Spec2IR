{
  "function_id": "alg_020_ml_kem_encaps",
  "name": "ML-KEM.Encaps",
  "label": "Algorithm 20",
  "page_start": 37,
  "page_end": 37,
  "inputs": [
    {
      "name": "ek",
      "type": "byte_array",
      "description": "384*k + 32-byte checked encapsulation key"
    }
  ],
  "outputs": [
    {
      "name": "K",
      "type": "byte_array",
      "description": "32-byte shared secret key, or ⊥ on randomness failure"
    },
    {
      "name": "c",
      "type": "byte_array",
      "description": "32*(d_u*k + d_v)-byte ciphertext, or ⊥ on randomness failure"
    }
  ],
  "body_raw": [
    "m <-$ B^32",
    "if m == NULL then",
    "  return ⊥",
    "end if",
    "(K, c) <- ML-KEM.Encaps_internal(ek, m)",
    "return (K, c)"
  ]
}