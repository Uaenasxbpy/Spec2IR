{
  "function_id": "alg_017_ml_kem_encaps_internal",
  "name": "ML-KEM.Encaps_internal",
  "label": "Algorithm 17",
  "page_start": 33,
  "page_end": 33,
  "inputs": [
    {
      "name": "ek",
      "type": "byte_array",
      "description": "384*k + 32-byte encapsulation key"
    },
    {
      "name": "m",
      "type": "byte_array",
      "description": "32-byte randomness"
    }
  ],
  "outputs": [
    {
      "name": "K",
      "type": "byte_array",
      "description": "32-byte shared secret key"
    },
    {
      "name": "c",
      "type": "byte_array",
      "description": "32*(d_u*k + d_v)-byte ciphertext"
    }
  ],
  "body_raw": [
    "(K, r) <- G(m || H(ek))",
    "c <- K-PKE.Encrypt(ek, m, r)",
    "return (K, c)"
  ]
}