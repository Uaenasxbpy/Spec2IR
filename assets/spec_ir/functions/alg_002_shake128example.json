{
  "function_id": "alg_002_shake128example",
  "name": "SHAKE128example",
  "label": "Algorithm 2",
  "page_start": 19,
  "page_end": 19,
  "inputs": [
    {
      "name": "strs",
      "type": "byte_array[]",
      "description": "Input byte arrays str1, ..., str_m"
    },
    {
      "name": "output_lengths",
      "type": "int[]",
      "description": "Output lengths b1, ..., b_l in bytes"
    }
  ],
  "outputs": [
    {
      "name": "output",
      "type": "byte_array",
      "description": "Concatenated output byte array of total length sum(b_j)"
    }
  ],
  "body_raw": [
    "ctx <- SHAKE128.Init()",
    "for (i <- 1; i <= m; i++)",
    "  ctx <- SHAKE128.Absorb(ctx, str_i)",
    "end for",
    "for (j <- 1; j <= l; j++)",
    "  (ctx, out_j) <- SHAKE128.Squeeze(ctx, 8 * b_j)",
    "end for",
    "output <- out1 || ... || out_l",
    "return output"
  ]
}