{
  "function_id": "alg_015_k_pke_decrypt",
  "name": "K-PKE.Decrypt",
  "label": "Algorithm 15",
  "page_start": 31,
  "page_end": 31,
  "inputs": [
    {
      "name": "dkPKE",
      "type": "byte_array",
      "description": "384*k-byte decryption key"
    },
    {
      "name": "c",
      "type": "byte_array",
      "description": "32*(d_u*k + d_v)-byte ciphertext"
    }
  ],
  "outputs": [
    {
      "name": "m",
      "type": "byte_array",
      "description": "32-byte decrypted plaintext message"
    }
  ],
  "body_raw": [
    "c1 <- c[0 : 32*d_u*k]",
    "c2 <- c[32*d_u*k : 32*(d_u*k + d_v)]",
    "u_prime <- Decompress_du(ByteDecode_du(c1))",
    "v_prime <- Decompress_dv(ByteDecode_dv(c2))",
    "s_hat <- ByteDecode_12(dkPKE)",
    "w <- v_prime - NTT_inverse(s_hat_transpose ∘ NTT(u_prime))",
    "m <- ByteEncode_1(Compress_1(w))",
    "return m"
  ]
}